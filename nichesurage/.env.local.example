# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_API_KEY_2=your_second_youtube_api_key

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe (test mode for development)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Resend
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sonar Discovery System
OUTLIER_DB_FLOOR=2
OUTLIER_SPIKE_THRESHOLD=5
OUTLIER_UI_THRESHOLD=5
SPIKING_NOW_THRESHOLD=10
SEEDS_PER_RUN=4
CLUSTERING_SIMILARITY=0.78
ORPHAN_BATCH_MIN=5
EMBED_BATCH=50
RETENTION_NON_SPIKE_DAYS=14
RETENTION_SPIKE_DAYS=60
# OpenAI used only for embeddings (text-embedding-3-small). Claude stays for labels.
OPENAI_API_KEY=

# PostHog (optional — leave unset for local dev, init becomes no-op)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (optional — leave unset for local dev, init becomes no-op)
# Same DSN value can be used for both. NEXT_PUBLIC_ exposes it to the browser.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Required only at build time for source-map upload.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
